model ProductVariantAttribute {
  id          String  @id @default(uuid()) @db.Uuid
  variantId   String  @map("variant_id") @db.Uuid
  attributeId String  @map("attribute_id") @db.Uuid
  valueId     String? @map("value_id") @db.Uuid
  value       String  @db.VarChar(500)

  variant     ProductVariant         @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attribute   ProductAttribute       @relation("ProductVariantAttributes", fields: [attributeId], references: [id], onDelete: Cascade)
  valueObj    ProductAttributeValue? @relation(fields: [valueId], references: [id], onDelete: SetNull, map: "fk_variant_attr_value")

  @@index([variantId])
  @@index([attributeId])
  @@index([valueId])
  @@map("product_variant_attributes")
}

model ProductVariant {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  sku             String?  @db.VarChar(100)
  barcode         String?  @db.VarChar(100)
  price           Decimal? @db.Decimal(15, 2)
  compareAtPrice  Decimal? @map("compare_at_price") @db.Decimal(15, 2)
  costPrice       Decimal? @map("cost_price") @db.Decimal(15, 2)
  quantity        Int      @default(0)
  isDefault       Boolean  @default(false) @map("is_default")
  isActive        Boolean  @default(true) @map("is_active")
  metadata        Json?    @db.JsonB
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  product             Product                  @relation("ProductVariants", fields: [productId], references: [id], onDelete: Cascade)
  attributes          ProductVariantAttribute[]
  cartItems           CartItem[]
  orderItems          OrderItem[]

  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

