  @@map("analytics_reports")
}

// ══════════════════════════════════════════════════════════════
// SYSTEM: API Keys, Webhooks, Feature Flags
// ══════════════════════════════════════════════════════════════

model ApiKey {
  id            String    @id @default(uuid()) @db.Uuid
  name          String    @db.VarChar(200)
  key           String    @unique @db.VarChar(500)
  keyPrefix     String    @map("key_prefix") @db.VarChar(20)
  scopes        String[]  @default([]) @db.VarChar(50)
  lastUsedAt    DateTime? @map("last_used_at") @db.Timestamptz
  expiresAt     DateTime? @map("expires_at") @db.Timestamptz
  revokedAt     DateTime? @map("revoked_at") @db.Timestamptz
  ipRestrictions String[] @default([]) @map("ip_restrictions") @db.VarChar(45)
  rateLimit     Int?      @map("rate_limit")
  metadata      Json?     @db.JsonB
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?      @map("user_id") @db.Uuid
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([key])
  @@map("api_keys")
}

model Webhook {
  id          String   @id @default(uuid()) @db.Uuid
  url         String   @db.Text
  description String?  @db.Text
  events      String[] @default([]) @db.VarChar(100)
  secret      String?  @db.VarChar(500)
  isActive    Boolean  @default(true) @map("is_active")
  retryCount  Int      @default(3) @map("retry_count")
  lastSentAt  DateTime? @map("last_sent_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organizationId String @map("organization_id") @db.Uuid

  deliveries WebhookDelivery[]

  @@index([organizationId])
  @@map("webhooks")
}

model WebhookDelivery {
  id            String   @id @default(uuid()) @db.Uuid
  event         String   @db.VarChar(100)
  payload       Json     @db.JsonB
  responseCode  Int?     @map("response_code")
  responseBody  String?  @map("response_body") @db.Text
  status        String   @default("PENDING") @db.VarChar(20)
  attempts      Int      @default(1)
  errorMessage  String?  @map("error_message") @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  completedAt   DateTime? @map("completed_at") @db.Timestamptz

  webhookId String  @map("webhook_id") @db.Uuid
  webhook   Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([status])
  @@map("webhook_deliveries")
}

model FeatureFlag {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @db.VarChar(200)
  slug            String   @db.VarChar(200)
  description     String?  @db.Text
  enabled         Boolean  @default(false)
  rules           Json?    @db.JsonB
  percentageRollout Int?   @map("percentage_rollout")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@map("feature_flags")
}

// ══════════════════════════════════════════════════════════════
// SEO: Redirects, SEO Meta Templates
// ══════════════════════════════════════════════════════════════

model Redirect {
  id          String   @id @default(uuid()) @db.Uuid
  source      String   @db.Text
  destination String   @db.Text
  statusCode  Int      @default(301) @map("status_code")
  isRegex     Boolean  @default(false) @map("is_regex")
  isActive    Boolean  @default(true) @map("is_active")
  hitCount    Int      @default(0) @map("hit_count")
  lastHitAt   DateTime? @map("last_hit_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organizationId String @map("organization_id") @db.Uuid

  @@index([organizationId])
  @@index([source])
  @@map("redirects")
}

