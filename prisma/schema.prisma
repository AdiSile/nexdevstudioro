  organizationId  String  @map("organization_id") @db.Uuid
  totalUsers      Int     @default(0) @map("total_users")
  totalProjects   Int     @default(0) @map("total_projects")
  totalOrders     Int     @default(0) @map("total_orders")
  totalRevenue    Decimal @default(0) @map("total_revenue") @db.Decimal(15, 2)
  totalAITokens   Int     @default(0) @map("total_ai_tokens")
  activeProjects  Int     @default(0) @map("active_projects")
