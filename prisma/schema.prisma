// ============================================================
// NexusDevStudio.ro — Enterprise AI-Powered Digital Platform
// Prisma Schema PostgreSQL | Multi-Tenant | Modular Monolith
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "multiSchema", "fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Extensions ──────────────────────────────────────────────
// CREATE EXTENSION IF NOT EXISTS "uuid-ossp";
// CREATE EXTENSION IF NOT EXISTS "pgcrypto";
// CREATE EXTENSION IF NOT EXISTS "pg_trgm";
// CREATE EXTENSION IF NOT EXISTS "vector";

// ══════════════════════════════════════════════════════════════
// ENUMS
// ══════════════════════════════════════════════════════════════

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
  PENDING_VERIFICATION
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  TRIAL
  GRACE_PERIOD
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOWEST
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ClientStatus {
  LEAD
  PROSPECT
  ACTIVE
  INACTIVE
  CHURNED
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  PAYPAL
  BANK_TRANSFER
  CRYPTO
  CASH
  OTHER
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  DISPUTED
}

enum OrderStatus {
  CART
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

enum ShippingStatus {
  PENDING
  PROCESSING
  IN_TRANSIT
  DELIVERED
  FAILED
  RETURNED
}

enum CMSStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  SCHEDULED
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  SCHEDULED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  POSTPONED
  COMPLETED
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  ATTENDED
  NO_SHOW
}

enum AIProvider {
  OPENAI
  ANTHROPIC
  GOOGLE
  MISTRAL
  DEEPSEEK
  XAI
  CUSTOM
}

enum AIModelType {
  CHAT
  COMPLETION
  EMBEDDING
  IMAGE
  AUDIO
  VIDEO
  MODERATION
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  WHATSAPP
  IN_APP
  WEBHOOK
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  BOUNCED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  VIEW
}

enum FileAccess {
  PRIVATE
  ORGANIZATION
  PUBLIC
  SHARED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  UNPAID
  TRIALING
  PAUSED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

enum CouponScope {
  ORDER
  PRODUCT
  CATEGORY
  SHIPPING
}

// ══════════════════════════════════════════════════════════════
// CORE: Organizații & Tenants
// ══════════════════════════════════════════════════════════════

model Organization {
  id          String             @id @default(uuid()) @db.Uuid
  name        String             @db.VarChar(255)
  slug        String             @unique @db.VarChar(255)
  legalName   String?            @db.VarChar(500)
  taxId       String?            @map("tax_id") @db.VarChar(100)
  email       String?            @db.VarChar(320)
  phone       String?            @db.VarChar(50)
  website     String?            @db.VarChar(500)
  logoUrl     String?            @map("logo_url") @db.Text
  faviconUrl  String?            @map("favicon_url") @db.Text
  branding    Json?              @db.JsonB
  status      OrganizationStatus @default(TRIAL)
  settings    Json?              @db.JsonB
  metadata    Json?              @db.JsonB
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime           @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?          @map("deleted_at") @db.Timestamptz

  users          User[]
  teams          Team[]
  clients        Client[]
  projects       Project[]
  invitations    Invitation[]
  apiKeys        ApiKey[]
  subscriptions  Subscription[]
  files          File[]
  auditLogs      AuditLog[]
  featureFlags   FeatureFlag[]

  @@map("organizations")
}

// ══════════════════════════════════════════════════════════════
// CORE: Utilizatori, Roluri, Permisiuni
// ══════════════════════════════════════════════════════════════

model User {
  id                  String        @id @default(uuid()) @db.Uuid
  email               String        @unique @db.VarChar(320)
  emailVerified       Boolean       @default(false) @map("email_verified")
  emailVerifiedAt     DateTime?     @map("email_verified_at") @db.Timestamptz
  passwordHash        String?       @map("password_hash") @db.VarChar(255)
  firstName           String?       @map("first_name") @db.VarChar(150)
  lastName            String?       @map("last_name") @db.VarChar(150)
  displayName         String?       @map("display_name") @db.VarChar(300)
  avatarUrl           String?       @map("avatar_url") @db.Text
  phone               String?       @db.VarChar(50)
  phoneVerified       Boolean       @default(false) @map("phone_verified")
  status              UserStatus    @default(PENDING_VERIFICATION)
  timezone            String?       @db.VarChar(100)
  locale              String?       @default("ro") @db.VarChar(10)
  theme               String?       @default("system") @db.VarChar(20)
  lastLoginAt         DateTime?     @map("last_login_at") @db.Timestamptz
  lastLoginIp         String?       @map("last_login_ip") @db.VarChar(45)
  failedLoginAttempts Int           @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?     @map("locked_until") @db.Timestamptz
  totpSecret          String?       @map("totp_secret") @db.VarChar(255)
  totpEnabled         Boolean       @default(false) @map("totp_enabled")
  recoveryCodes       String?       @map("recovery_codes") @db.Text
  metadata            Json?         @db.JsonB
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime?     @map("deleted_at") @db.Timestamptz

  organizationId String?      @map("organization_id") @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  defaultRoleId  String?      @map("default_role_id") @db.Uuid
  defaultRole    Role?        @relation("UserDefaultRole", fields: [defaultRoleId], references: [id], onDelete: SetNull)

  organizationRoles  UserOrganizationRole[]
  sessions           Session[]
  accounts           Account[]
  teamMembers        TeamMember[]
  assignedTasks      Task[]              @relation("TaskAssignee")
  createdTasks       Task[]              @relation("TaskCreator")
  notifications      Notification[]
  notificationPrefs  NotificationPreference[]
  subscriptions      Subscription[]
  apiKeys            ApiKey[]
  auditLogs          AuditLog[]
  files              File[]
  blogPosts          BlogPost[]
  comments           Comment[]
  orders             Order[]
  reviews            Review[]
  wishlists          Wishlist[]
  tickets            Ticket[]
  ticketMessages     TicketMessage[]
  eventRegistrations EventRegistration[]
  aiConversations    AIConversation[]
  aiCredits          AICredit[]
  aiUsage            AIUsage[]
  addresses          Address[]
  invoices           Invoice[]
  certificates       Certificate[]
  messages           Message[]           @relation("MessageSender")
  messageReceipts    MessageReceipt[]
  workflowExecutions WorkflowExecution[]

  @@index([email], type: Hash)
  @@index([organizationId])
  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(150)
  slug        String    @db.VarChar(150)
  description String?   @db.Text
  isSystem    Boolean   @default(false) @map("is_system")
  isDefault   Boolean   @default(false) @map("is_default")
  level       Int       @default(0)
  metadata    Json?     @db.JsonB
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  organizationId String?      @map("organization_id") @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentRoleId   String?      @map("parent_role_id") @db.Uuid
  parentRole     Role?        @relation("RoleHierarchy", fields: [parentRoleId], references: [id], onDelete: SetNull)
  childRoles     Role[]       @relation("RoleHierarchy")

  rolePermissions   RolePermission[]
  userOrgRoles      UserOrganizationRole[]
  defaultForUsers   User[]              @relation("UserDefaultRole")

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@index([slug])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(200)
  slug        String   @unique @db.VarChar(200)
  resource    String   @db.VarChar(100)
  action      String   @db.VarChar(100)
  description String?  @db.Text
  module      String?  @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  rolePermissions RolePermission[]

  @@index([resource])
  @@index([module])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserOrganizationRole {
  id             String @id @default(uuid()) @db.Uuid
  userId         String @map("user_id") @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  roleId         String @map("role_id") @db.Uuid
  isPrimary      Boolean @default(false) @map("is_primary")
  assignedAt     DateTime @default(now()) @map("assigned_at") @db.Timestamptz
  expiresAt      DateTime? @map("expires_at") @db.Timestamptz

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, roleId])
  @@index([userId])
  @@index([organizationId])
  @@map("user_organization_roles")
}

// ══════════════════════════════════════════════════════════════
// AUTH: Sesiuni, Conturi OAuth, Invitații
// ══════════════════════════════════════════════════════════════

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token") @db.VarChar(500)
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime @db.Timestamptz
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent") @db.Text
  deviceInfo   Json?    @map("device_info") @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
  @@map("sessions")
}

model Account {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  type              String   @db.VarChar(50)
  provider          String   @db.VarChar(50)
  providerAccountId String   @map("provider_account_id") @db.VarChar(255)
  refreshToken      String?  @map("refresh_token") @db.Text
  accessToken       String?  @map("access_token") @db.Text
  expiresAt         Int?     @map("expires_at")
  tokenType         String?  @map("token_type") @db.VarChar(50)
  scope             String?  @db.Text
  idToken           String?  @map("id_token") @db.Text
  sessionState      String?  @map("session_state") @db.Text
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Invitation {
  id             String    @id @default(uuid()) @db.Uuid
  email          String    @db.VarChar(320)
  organizationId String    @map("organization_id") @db.Uuid
  roleId         String?   @map("role_id") @db.Uuid
  invitedBy      String    @map("invited_by") @db.Uuid
  token          String    @unique @db.VarChar(500)
  status         String    @default("PENDING") @db.VarChar(20)
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz
  acceptedAt     DateTime? @map("accepted_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([organizationId])
  @@index([token])
  @@map("invitations")
}

// ══════════════════════════════════════════════════════════════
// CORE: Echipe
// ══════════════════════════════════════════════════════════════

model Team {
  id             String    @id @default(uuid()) @db.Uuid
  name           String    @db.VarChar(200)
  slug           String    @db.VarChar(200)
  description    String?   @db.Text
  color          String?   @db.VarChar(20)
  icon           String?   @db.VarChar(50)
  isDefault      Boolean   @default(false) @map("is_default")
  metadata       Json?     @db.JsonB
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadId         String?      @map("lead_id") @db.Uuid

  members   TeamMember[]
  projects  Project[]

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String   @default("MEMBER") @db.VarChar(50)
  joinedAt  DateTime @default(now()) @map("joined_at") @db.Timestamptz

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

// ══════════════════════════════════════════════════════════════
// CRM: Clienți
// ══════════════════════════════════════════════════════════════

model Client {
  id              String       @id @default(uuid()) @db.Uuid
  type            String       @default("INDIVIDUAL") @db.VarChar(20)
  companyName     String?      @map("company_name") @db.VarChar(300)
  firstName       String?      @map("first_name") @db.VarChar(150)
  lastName        String?      @map("last_name") @db.VarChar(150)
  email           String       @db.VarChar(320)
  phone           String?      @db.VarChar(50)
  status          ClientStatus @default(LEAD)
  source          String?      @db.VarChar(100)
  assignedToId    String?      @map("assigned_to_id") @db.Uuid
  notes           String?      @db.Text
  tags            String[]     @default([]) @db.VarChar(50)
  customFields    Json?        @map("custom_fields") @db.JsonB
  lifetimeValue   Decimal?     @default(0) @map("lifetime_value") @db.Decimal(15, 2)
  lastContactedAt DateTime?    @map("last_contacted_at") @db.Timestamptz
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?    @map("deleted_at") @db.Timestamptz

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  projects  Project[]
  orders    Order[]
  invoices  Invoice[]
  tickets   Ticket[]
  addresses Address[]

  @@index([email])
  @@index([organizationId])
  @@index([status])
  @@index([assignedToId])
  @@map("clients")
}

model Address {
  id          String    @id @default(uuid()) @db.Uuid
  type        String    @default("BILLING") @db.VarChar(20)
  line1       String    @db.VarChar(500)
  line2       String?   @db.VarChar(500)
  city        String    @db.VarChar(200)
  state       String?   @db.VarChar(200)
  postalCode  String?   @map("postal_code") @db.VarChar(50)
  country     String    @default("RO") @db.VarChar(2)
  isDefault   Boolean   @default(false) @map("is_default")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  userId   String? @map("user_id") @db.Uuid
  user     User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  clientId String? @map("client_id") @db.Uuid
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  orderId  String? @map("order_id") @db.Uuid
  order    Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([clientId])
  @@map("addresses")
}

// ══════════════════════════════════════════════════════════════
// PROIECTE & TASK-URI
// ══════════════════════════════════════════════════════════════

model Project {
  id              String        @id @default(uuid()) @db.Uuid
  name            String        @db.VarChar(300)
  slug            String        @db.VarChar(300)
  description     String?       @db.Text
  status          ProjectStatus @default(DRAFT)
  priority        TaskPriority  @default(MEDIUM)
  startDate       DateTime?     @map("start_date") @db.Date
  endDate         DateTime?     @map("end_date") @db.Date
  budget          Decimal?      @db.Decimal(15, 2)
  currency        String        @default("EUR") @db.VarChar(3)
  progressPercent Int           @default(0) @map("progress_percent")
  isPublic        Boolean       @default(false) @map("is_public")
  settings        Json?         @db.JsonB
  metadata        Json?         @db.JsonB
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teamId         String?      @map("team_id") @db.Uuid
  team           Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  clientId       String?      @map("client_id") @db.Uuid
  client         Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  leadId         String?      @map("lead_id") @db.Uuid

  tasks       Task[]
  files       File[]
  calendarEvents CalendarEvent[]

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@index([teamId])
  @@index([clientId])
  @@index([status])
  @@map("projects")
}

model Task {
  id              String       @id @default(uuid()) @db.Uuid
  title           String       @db.VarChar(500)
  description     String?      @db.Text
  status          TaskStatus   @default(TODO)
  priority        TaskPriority @default(MEDIUM)
  order           Int          @default(0)
  dueDate         DateTime?    @map("due_date") @db.Timestamptz
  completedAt     DateTime?    @map("completed_at") @db.Timestamptz
  estimatedHours  Decimal?     @map("estimated_hours") @db.Decimal(8, 2)
  actualHours     Decimal?     @map("actual_hours") @db.Decimal(8, 2)
  tags            String[]     @default([]) @db.VarChar(50)
  metadata        Json?        @db.JsonB
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?    @map("deleted_at") @db.Timestamptz

  projectId       String  @map("project_id") @db.Uuid
  project         Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId      String? @map("assignee_id") @db.Uuid
  assignee        User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creatorId       String? @map("creator_id") @db.Uuid
  creator         User?   @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  parentTaskId    String? @map("parent_task_id") @db.Uuid
  parentTask      Task?   @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks        Task[]  @relation("TaskSubtasks")

  comments      TaskComment[]
  timeEntries   TimeEntry[]
  dependencies  TaskDependency[] @relation("TaskDependencySource")
  dependentOn   TaskDependency[] @relation("TaskDependencyTarget")
  files         File[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
  @@index([parentTaskId])
  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(uuid()) @db.Uuid
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  taskId String @map("task_id") @db.Uuid
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String @map("user_id") @db.Uuid

  @@index([taskId])
  @@map("task_comments")
}

model TaskDependency {
  id             String @id @default(uuid()) @db.Uuid
  sourceTaskId   String @map("source_task_id") @db.Uuid
  targetTaskId   String @map("target_task_id") @db.Uuid
  dependencyType String @default("BLOCKS") @map("dependency_type") @db.VarChar(20)

  sourceTask Task @relation("TaskDependencySource", fields: [sourceTaskId], references: [id], onDelete: Cascade)
  targetTask Task @relation("TaskDependencyTarget", fields: [targetTaskId], references: [id], onDelete: Cascade)

  @@unique([sourceTaskId, targetTaskId])
  @@map("task_dependencies")
}

model TimeEntry {
  id          String   @id @default(uuid()) @db.Uuid
  description String?  @db.Text
  startTime   DateTime @map("start_time") @db.Timestamptz
  endTime     DateTime? @map("end_time") @db.Timestamptz
  duration    Int?
  billable    Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  taskId String @map("task_id") @db.Uuid
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String @map("user_id") @db.Uuid

  @@index([taskId])
  @@index([userId])
  @@map("time_entries")
}

// ══════════════════════════════════════════════════════════════
// CALENDAR
// ══════════════════════════════════════════════════════════════

model CalendarEvent {
  id          String    @id @default(uuid()) @db.Uuid
  title       String    @db.VarChar(500)
  description String?   @db.Text
  location    String?   @db.VarChar(500)
  startTime   DateTime  @map("start_time") @db.Timestamptz
  endTime     DateTime  @map("end_time") @db.Timestamptz
  allDay      Boolean   @default(false) @map("all_day")
  color       String?   @db.VarChar(20)
  recurrence  String?   @db.VarChar(200)
  externalId  String?   @map("external_id") @db.VarChar(500)
  metadata    Json?     @db.JsonB
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  projectId    String?  @map("project_id") @db.Uuid
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  organizerId  String   @map("organizer_id") @db.Uuid
  organizationId String @map("organization_id") @db.Uuid

  @@index([organizerId])
  @@index([organizationId])
  @@index([startTime])
  @@index([projectId])
  @@map("calendar_events")
}

// ══════════════════════════════════════════════════════════════
// CMS: Pagini, Navigație, Media
// ══════════════════════════════════════════════════════════════

model CMSPage {
  id             String    @id @default(uuid()) @db.Uuid
  title          String    @db.VarChar(500)
  slug           String    @db.VarChar(500)
  content        Json?     @db.JsonB
  excerpt        String?   @db.Text
  featuredImage  String?   @map("featured_image") @db.Text
  status         CMSStatus @default(DRAFT)
  template       String?   @db.VarChar(100)
  layout         String?   @db.VarChar(100)
  seoTitle       String?   @map("seo_title") @db.VarChar(300)
  seoDescription String?   @map("seo_description") @db.Text
  seoKeywords    String?   @map("seo_keywords") @db.Text
  ogImage        String?   @map("og_image") @db.Text
  canonicalUrl   String?   @map("canonical_url") @db.Text
  noIndex        Boolean   @default(false) @map("no_index")
  publishedAt    DateTime? @map("published_at") @db.Timestamptz
  scheduledAt    DateTime? @map("scheduled_at") @db.Timestamptz
  sortOrder      Int       @default(0) @map("sort_order")
  metadata       Json?     @db.JsonB
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  organizationId String  @map("organization_id") @db.Uuid
  authorId       String? @map("author_id") @db.Uuid
  parentPageId   String? @map("parent_page_id") @db.Uuid
  parentPage     CMSPage? @relation("CMSPageHierarchy", fields: [parentPageId], references: [id], onDelete: SetNull)
  childPages     CMSPage[] @relation("CMSPageHierarchy")

  versions    CMSPageVersion[]
  navigationItems NavigationItem[]

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@index([status])
  @@index([parentPageId])
  @@map("cms_pages")
}

model CMSPageVersion {
  id        String   @id @default(uuid()) @db.Uuid
  version   Int
  content   Json     @db.JsonB
  changelog String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  pageId String @map("page_id") @db.Uuid
  page   CMSPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  userId String @map("user_id") @db.Uuid

  @@index([pageId])
  @@map("cms_page_versions")
}

model NavigationMenu {
  id             String    @id @default(uuid()) @db.Uuid
  name           String    @db.VarChar(200)
  slug           String    @db.VarChar(200)
  location       String    @db.VarChar(50)
  isActive       Boolean   @default(true) @map("is_active")
  settings       Json?     @db.JsonB
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  organizationId String           @map("organization_id") @db.Uuid
  items          NavigationItem[]

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@map("navigation_menus")
}

model NavigationItem {
  id            String    @id @default(uuid()) @db.Uuid
  label         String    @db.VarChar(300)
  url           String?   @db.Text
  type          String    @default("LINK") @db.VarChar(20)
  target        String?   @default("_self") @db.VarChar(20)
  icon          String?   @db.VarChar(50)
  classes       String?   @db.VarChar(300)
  sortOrder     Int       @default(0) @map("sort_order")
  isActive      Boolean   @default(true) @map("is_active")
  visibilityRules Json?   @map("visibility_rules") @db.JsonB
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  menuId        String          @map("menu_id") @db.Uuid
  menu          NavigationMenu  @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parentItemId  String?         @map("parent_item_id") @db.Uuid
  parentItem    NavigationItem? @relation("NavItemHierarchy", fields: [parentItemId], references: [id], onDelete: SetNull)
  children      NavigationItem[] @relation("NavItemHierarchy")
  pageId        String?         @map("page_id") @db.Uuid
  page          CMSPage?        @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@index([menuId])
  @@index([parentItemId])
  @@map("navigation_items")
}

model CMSForm {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(300)
  slug        String   @db.VarChar(300)
  fields      Json     @db.JsonB
  settings    Json?    @db.JsonB
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organizationId String          @map("organization_id") @db.Uuid
  submissions    CMSFormSubmission[]

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@map("cms_forms")
}

model CMSFormSubmission {
  id        String    @id @default(uuid()) @db.Uuid
  data      Json      @db.JsonB
  isRead    Boolean   @default(false) @map("is_read")
  ipAddress String?   @map("ip_address") @db.VarChar(45)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  formId String  @map("form_id") @db.Uuid
  form   CMSForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@map("cms_form_submissions")
}

// ══════════════════════════════════════════════════════════════
// BLOG
// ══════════════════════════════════════════════════════════════

model BlogPost {
  id              String     @id @default(uuid()) @db.Uuid
  title           String     @db.VarChar(500)
  slug            String     @db.VarChar(500)
  content         Json?      @db.JsonB
  excerpt         String?    @db.Text
  featuredImage   String?    @map("featured_image") @db.Text
  status          BlogStatus @default(DRAFT)
  readingTime     Int?       @map("reading_time")
  seoTitle        String?    @map("seo_title") @db.VarChar(300)
  seoDescription  String?    @map("seo_description") @db.Text
  seoKeywords     String?    @map("seo_keywords") @db.Text
  ogImage         String?    @map("og_image") @db.Text
  canonicalUrl    String?    @map("canonical_url") @db.Text
  noIndex         Boolean    @default(false) @map("no_index")
  isFeatured      Boolean    @default(false) @map("is_featured")
  viewCount       Int        @default(0) @map("view_count")
  publishedAt     DateTime?  @map("published_at") @db.Timestamptz
  scheduledAt     DateTime?  @map("scheduled_at") @db.Timestamptz
  metadata        Json?      @db.JsonB
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?  @map("deleted_at") @db.Timestamptz

  organizationId String  @map("organization_id") @db.Uuid
  authorId       String? @map("author_id") @db.Uuid
  author         User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  categories  BlogCategoryOnPost[]
  tags        BlogTagOnPost[]
  comments    Comment[]
  aIInsights  AIInsight[]

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@index([authorId])
  @@index([status])
  @@index([publishedAt])
  @@map("blog_posts")
}

model BlogCategory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(200)
  slug        String    @db.VarChar(200)
  description String?   @db.Text
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  organizationId String              @map("organization_id") @db.Uuid
  posts          BlogCategoryOnPost[]

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@map("blog_categories")
}

model BlogTag {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(150)
  slug      String   @db.VarChar(150)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  organizationId String          @map("organization_id") @db.Uuid
  posts          BlogTagOnPost[]

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@map("blog_tags")
}

model BlogCategoryOnPost {
  blogPostId String @map("blog_post_id") @db.Uuid
  categoryId String @map("category_id") @db.Uuid

  blogPost BlogPost     @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  category BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([blogPostId, categoryId])
  @@map("blog_category_on_post")
}

model BlogTagOnPost {
  blogPostId String @map("blog_post_id") @db.Uuid
  tagId      String @map("tag_id") @db.Uuid

  blogPost BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  tag      BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([blogPostId, tagId])
  @@map("blog_tag_on_post")
}

model Comment {
  id        String    @id @default(uuid()) @db.Uuid
  content   String    @db.Text
  status    String    @default("APPROVED") @db.VarChar(20)
  ipAddress String?   @map("ip_address") @db.VarChar(45)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  blogPostId    String?   @map("blog_post_id") @db.Uuid
  blogPost      BlogPost? @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  productId     String?   @map("product_id") @db.Uuid
  product       Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  authorId      String?   @map("author_id") @db.Uuid
  author        User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorName    String?   @map("author_name") @db.VarChar(200)
  authorEmail   String?   @map("author_email") @db.VarChar(320)
  parentCommentId String? @map("parent_comment_id") @db.Uuid
  parentComment   Comment? @relation("CommentThread", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies         Comment[] @relation("CommentThread")

  @@index([blogPostId])
  @@index([productId])
  @@index([authorId])
  @@index([parentCommentId])
  @@map("comments")
}

// ══════════════════════════════════════════════════════════════
// SHOP: Produse, Comenzi, Cupoane
// ══════════════════════════════════════════════════════════════

model ProductCategory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(300)
  slug        String    @db.VarChar(300)
  description String?   @db.Text
  imageUrl    String?   @map("image_url") @db.Text
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  seoTitle    String?   @map("seo_title") @db.VarChar(300)
  seoDesc     String?   @map("seo_description") @db.Text
  metadata    Json?     @db.JsonB
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  organizationId String             @map("organization_id") @db.Uuid
  parentCategoryId String?          @map("parent_category_id") @db.Uuid
  parentCategory   ProductCategory? @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id], onDelete: SetNull)
  childCategories  ProductCategory[] @relation("CategoryHierarchy")
  products         Product[]

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@index([parentCategoryId])
  @@map("product_categories")
}

model Product {
  id              String    @id @default(uuid()) @db.Uuid
  name            String    @db.VarChar(500)
  slug            String    @db.VarChar(500)
  sku             String?   @unique @db.VarChar(150)
  description     String?   @db.Text
  content         Json?     @db.JsonB
  type            String    @default("PHYSICAL") @db.VarChar(20)
  status          String    @default("DRAFT") @db.VarChar(20)
  price           Decimal   @db.Decimal(15, 2)
  compareAtPrice  Decimal?  @map("compare_at_price") @db.Decimal(15, 2)
  costPrice       Decimal?  @map("cost_price") @db.Decimal(15, 2)
  currency        String    @default("EUR") @db.VarChar(3)
  taxRate         Decimal?  @default(0) @map("tax_rate") @db.Decimal(5, 2)
  weight          Decimal?  @db.Decimal(10, 3)
  weightUnit      String?   @default("kg") @map("weight_unit") @db.VarChar(10)
  stockQuantity   Int       @default(0) @map("stock_quantity")
  lowStockAlert   Int?      @map("low_stock_alert")
  isDigital       Boolean   @default(false) @map("is_digital")
  digitalFileUrl  String?   @map("digital_file_url") @db.Text
  isFeatured      Boolean   @default(false) @map("is_featured")
  isTaxable       Boolean   @default(true) @map("is_taxable")
  seoTitle        String?   @map("seo_title") @db.VarChar(300)
  seoDescription  String?   @map("seo_description") @db.Text
  ogImage         String?   @map("og_image") @db.Text
  metadata        Json?     @db.JsonB
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  organizationId String          @map("organization_id") @db.Uuid
  categoryId     String?         @map("category_id") @db.Uuid
  category       ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brandId        String?         @map("brand_id") @db.Uuid
  brand          Brand?          @relation(fields: [brandId], references: [id], onDelete: SetNull)

  variants    ProductVariant[]
  images      ProductImage[]
  attributes  ProductAttributeValue[]
  reviews     Review[]
  comments    Comment[]
  orderItems  OrderItem[]
  cartItems   CartItem[]
  wishlists   Wishlist[]
  coupons     Coupon[]
  bundles     BundleProduct[]
  crossSells  CrossSell[]       @relation("CrossSellSource")
  crossSoldBy CrossSell[]       @relation("CrossSellTarget")

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@index([categoryId])
  @@index([brandId])
  @@index([status])
  @@index([sku])
  @@map("products")
}

model Brand {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(200)
  slug        String   @db.VarChar(200)
  description String?  @db.Text
  logoUrl     String?  @map("logo_url") @db.Text
  website     String?  @db.VarChar(500)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organizationId String    @map("organization_id") @db.Uuid
  products       Product[]

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@map("brands")
}

model ProductVariant {
  id            String  @id @default(uuid()) @db.Uuid
  name          String  @db.VarChar(300)
  sku           String? @unique @db.VarChar(150)
  price         Decimal? @db.Decimal(15, 2)
  stockQuantity Int     @default(0) @map("stock_quantity")
  isDefault     Boolean @default(false) @map("is_default")
  sortOrder     Int     @default(0) @map("sort_order")
  metadata      Json?   @db.JsonB

  productId String  @map("product_id") @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  attributes ProductVariantAttribute[]
  orderItems OrderItem[]

  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

model ProductAttribute {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(200)
  slug      String   @db.VarChar(200)
  type      String   @default("TEXT") @db.VarChar(20)
  options   Json?    @db.JsonB
  isGlobal  Boolean  @default(true) @map("is_global")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  organizationId String  @map("organization_id") @db.Uuid

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@map("product_attributes")
}

model ProductAttributeValue {
  id    String @id @default(uuid()) @db.Uuid
  value String @db.VarChar(500)

  productId   String           @map("product_id") @db.Uuid
  product     Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeId String           @map("attribute_id") @db.Uuid
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([productId, attributeId])
  @@index([attributeId])
  @@map("product_attribute_values")
}

model ProductVariantAttribute {
  id    String @id @default(uuid()) @db.Uuid
  value String @db.VarChar(500)

  variantId   String           @map("variant_id") @db.Uuid
  variant     ProductVariant   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeId String           @map("attribute_id") @db.Uuid
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([variantId, attributeId])
  @@map("product_variant_attributes")
}

model ProductImage {
  id        String   @id @default(uuid()) @db.Uuid
  url       String   @db.Text
  alt       String?  @db.VarChar(500)
  sortOrder Int      @default(0) @map("sort_order")
  isPrimary Boolean  @default(false) @map("is_primary")

  productId String  @map("product_id") @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model BundleProduct {
  id         String  @id @default(uuid()) @db.Uuid
  quantity   Int     @default(1)
  bundleId   String  @map("bundle_id") @db.Uuid
  bundle     Product @relation("BundleProducts", fields: [bundleId], references: [id], onDelete: Cascade)
  productId  String  @map("product_id") @db.Uuid
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([bundleId, productId])
  @@map("bundle_products")
}

model CrossSell {
  id             String  @id @default(uuid()) @db.Uuid
  type           String  @default("CROSS_SELL") @db.VarChar(20)
  sourceProductId String @map("source_product_id") @db.Uuid
  sourceProduct   Product @relation("CrossSellSource", fields: [sourceProductId], references: [id], onDelete: Cascade)
  targetProductId String @map("target_product_id") @db.Uuid
  targetProduct   Product @relation("CrossSellTarget", fields: [targetProductId], references: [id], onDelete: Cascade)

  @@unique([sourceProductId, targetProductId])
  @@map("cross_sells")
}

model Review {
  id        String   @id @default(uuid()) @db.Uuid
  rating    Int
  title     String?  @db.VarChar(300)
  content   String?  @db.Text
  isVerified Boolean @default(false) @map("is_verified")
  isVisible Boolean  @default(true) @map("is_visible")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  productId String  @map("product_id") @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String? @map("user_id") @db.Uuid
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([userId])
  @@map("reviews")
}

// ══════════════════════════════════════════════════════════════
// SHOP: Coș, Comenzi, Livrare
// ══════════════════════════════════════════════════════════════

model CartItem {
  id        String   @id @default(uuid()) @db.Uuid
  quantity  Int      @default(1)
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  userId    String?  @map("user_id") @db.Uuid
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String   @map("product_id") @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?  @map("variant_id") @db.Uuid
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  sessionId String?  @map("session_id") @db.VarChar(500)

  @@index([userId])
  @@index([sessionId])
  @@index([productId])
  @@map("cart_items")
}

model Order {
  id              String       @id @default(uuid()) @db.Uuid
  orderNumber     String       @unique @map("order_number") @db.VarChar(50)
  status          OrderStatus  @default(PENDING)
  subtotal        Decimal      @db.Decimal(15, 2)
  taxAmount       Decimal      @default(0) @map("tax_amount") @db.Decimal(15, 2)
  shippingAmount  Decimal      @default(0) @map("shipping_amount") @db.Decimal(15, 2)
  discountAmount  Decimal      @default(0) @map("discount_amount") @db.Decimal(15, 2)
  total           Decimal      @db.Decimal(15, 2)
  currency        String       @default("EUR") @db.VarChar(3)
  notes           String?      @db.Text
  customerNotes   String?      @map("customer_notes") @db.Text
  ipAddress       String?      @map("ip_address") @db.VarChar(45)
  metadata        Json?        @db.JsonB
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  organizationId String  @map("organization_id") @db.Uuid
  userId         String? @map("user_id") @db.Uuid
  user           User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  clientId       String? @map("client_id") @db.Uuid
  client         Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  couponId       String? @map("coupon_id") @db.Uuid
  coupon         Coupon? @relation(fields: [couponId], references: [id], onDelete: SetNull)

  items        OrderItem[]
  payments     Payment[]
  invoices     Invoice[]
  shipments    Shipment[]
  addresses    Address[]

  @@index([organizationId])
  @@index([userId])
  @@index([clientId])
